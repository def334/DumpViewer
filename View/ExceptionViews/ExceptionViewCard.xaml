<UserControl x:Class="DumpViewer.View.ExceptionViews.ExceptionViewCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:view="clr-namespace:DumpViewer.View.ExceptionViews"
             d:DataContext="{d:DesignInstance Type=view:ExceptionViewModel}"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <UserControl.Resources>
        <Style TargetType="Border">
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="BorderBrush" Value="#FFE5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF6B7280" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF111827" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="StackAddressItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Background" Value="#FFF9FAFB" />
            <Setter Property="BorderBrush" Value="#FFE5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="20,18,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Exception Info"
                   FontSize="32"
                   FontWeight="Bold"
                   Foreground="DarkGray" />

        <Border Grid.Row="2" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 기존 2열 유지 -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="예외 코드" Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding ExceptionCode}" Style="{StaticResource ValueStyle}" />

                        <TextBlock Text="추가 참조" Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding FaultModule}" Style="{StaticResource ValueStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="오류 주소" Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding FaultAddress}" Style="{StaticResource ValueStyle}" />

                        <TextBlock Text="스레드 ID" Style="{StaticResource LabelStyle}" />
                        <TextBlock Text="{Binding ThreadId}" Style="{StaticResource ValueStyle}" />
                    </StackPanel>
                </Grid>

                <!-- 추가: 한 열 스택 주소 목록 -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="스택 주소 목록" Style="{StaticResource LabelStyle}" />
                    <ListBox BorderThickness="0"
                             Background="Transparent"
                             ItemContainerStyle="{StaticResource StackAddressItemStyle}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             MaxHeight="220"
                             ItemsSource="{Binding StackList}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Addr}"
                                               FontFamily="Consolas"
                                               Foreground="#FF374151" />

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Value}"
                                               Margin="12,0,0,0"
                                               FontFamily="Consolas"
                                               Foreground="#FF111827" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>